{
  "schema_version": 1,
  "mode": "http",
  "profile": "strict_latency",
  "params": {
    "latency_threshold_ms": 180.0,
    "availability_threshold": 0.999
  },
  "alerts": {
    "enabled": true,
    "on_violation": true,
    "fail_open": true,
    "slack": {
      "webhook_url": "https://hooks.slack.com/services/REPLACE/ME",
      "timeout_seconds": 5
    },
    "pagerduty": {
      "routing_key": "env:NEURALBUDGET_PAGERDUTY_ROUTING_KEY",
      "severity": "error",
      "source": "neuralbudget",
      "component": "api-gateway",
      "group": "slo",
      "class": "violation",
      "timeout_seconds": 5
    },
    "opsgenie": {
      "api_key": "env:NEURALBUDGET_OPSGENIE_API_KEY",
      "priority": "P3",
      "source": "neuralbudget",
      "tags": ["neuralbudget", "http", "slo-violation"],
      "timeout_seconds": 5
    }
  }
}
